# Queue API — base URL of the Next.js frontend (Vercel or local dev)
API_BASE_URL=https://dynamic-research.vercel.app

# Agent auth — must match AGENT_SECRET_KEY in the frontend's env
AGENT_SECRET_KEY=

# Supabase — for uploading final outputs to Storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Worker config
POLL_INTERVAL_MS=30000
MAX_JOB_DURATION_MS=5400000
WORKING_DIR=/c/tmp/research-compare
