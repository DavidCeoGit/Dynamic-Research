# Queue API — base URL of the Next.js frontend (Vercel or local dev)
API_BASE_URL=https://dynamic-research.vercel.app

# Agent auth — must match AGENT_SECRET_KEY in the frontend's env
AGENT_SECRET_KEY=

# Supabase — for uploading final outputs to Storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Worker config
POLL_INTERVAL_MS=30000
MAX_JOB_DURATION_MS=5400000
WORKING_DIR=/c/tmp/research-compare

# --- S58 Phase 1 MVP — Plan-review gate ---
# Documentation/final-plan-design-gate.md §6 + §8 + §9.
# Per [[feedback_vercel_env_add_stdin_trailing_newline]], when adding these
# via `vercel env add`, use `printf "%s"` (NOT `echo`) to avoid trailing
# newline being stored. Consumers also call .trim() defensively.

# Gemini API key — from console.gemini.dev (paid prod tier). Dev-time CLI uses
# OAuth subscription; production worker MUST use a paid API key.
GEMINI_API_KEY=

# OpenAI API key — from platform.openai.com (paid prod tier). Dev-time Codex
# CLI uses ChatGPT OAuth subscription quota; production worker MUST use a paid
# API key. Per design §6 the model is gpt-5.5 once GA, fallback gpt-5.
OPENAI_API_KEY=

# Plan-review enforce flag. Set to "false" for dark-launch / shadow review
# (review runs, telemetry written, but verdict does NOT gate spawn) for the
# first ~10 jobs per design §8 Q4. Set to "true" for full enforcement.
PLAN_REVIEW_ENFORCE=true

# Cost ceiling per job in CENTS. Default 500 (= $5). If review-cycle cost
# exceeds this, the review aborts with status=BLOCKED (plan-quality blocked
# because plan triggered too many revisions; NOT system-blocked).
MAX_REVIEW_COST_CENTS=500

# Wall-clock cap for a single reviewPlan() call in MILLISECONDS. Default
# 900000 (= 15 minutes). On timeout the review marks SYSTEM_BLOCKED and the
# worker schedules auto-retry per design §6 (5m, 15m, 45m, 2h15m, 6h45m,
# 20h15m, max 6 attempts).
REVIEW_TIMEOUT_MS=900000

# Max sequential review rounds. Default 2 per design §8 Q1. Each round is
# Gemini -> integrate -> Codex -> integrate.
MAX_REVIEW_ROUNDS=2

# --- S62 Bug 52 fix — Gemini reviewer engagement knobs ---
# These are OPTIONAL. Defaults are baked into plan-transports.ts. Set them
# only when tuning the Gemini reviewer's engagement quality (e.g. if findings
# return to a rubber-stamp pattern after a model upgrade).
#
# Bug 52 (S62 2026-05-27): on n=2 production telemetry, Gemini emitted 0
# findings on plans that Codex flagged with 7-9 findings (31 output tokens
# vs Codex's 2800+). Root cause was Gemini-3.1-pro-preview defaulting to
# minimal thinking + no strict-reviewer framing. These knobs fix that.

# Reasoning depth for Gemini 3.x models. Values: low | medium | high.
# Per Codex MRPF v2 MAJOR-1 (S62): Gemini 3.x uses `thinkingLevel`. Gemini 3.1
# Pro cannot disable thinking — the level only controls reasoning depth.
GEMINI_THINKING_LEVEL=high

# Temperature 0-2; default 0.3 for deterministic review judgment. Higher
# values cause Gemini to over-defer / produce compliant-but-shallow output.
GEMINI_TEMPERATURE=0.3

# System instruction framing the model as a strict peer reviewer. Empty or
# unset falls back to the baked-in default in plan-transports.ts. Override
# only if you need to A/B different reviewer-persona prompts.
GEMINI_SYSTEM_INSTRUCTION=

# --- S64 Preflight cost + failure-loop architecture ---
# Documentation/preflight-cost-architecture-design-gate.md §3.4.

# Operator email recipient for preflight backoff + terminal-exit + recovery
# alerts. Distinct from per-job notify_email (which goes to the submitter).
# When unset, the Resend operator alert is skipped with a logged warning;
# the file-backed circuit breaker still functions (no behavioral regression,
# just no email visibility). Use a team alias like ops@your-domain.com.
PREFLIGHT_NOTIFY_EMAIL=
